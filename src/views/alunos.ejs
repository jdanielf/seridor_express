<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alunos</title>
</head>
<body>
    <h1>Lista de Alunos</h1>
    <% alunos.forEach(aluno => { %>
        <div>
            Aluno: <%= aluno.aluno %>
            <ul>
                <li>Matrícula: <%= aluno.Mat %></li>
                <li>Curso: <%= aluno.curso %></li>
                <li>Nome Completo: <%= aluno.Name %></li>
                <li>Telefone: <%= aluno.Telefone %></li>
                <li>Email: <%= aluno.email %></li>

            </ul>
        </div>
    <% }) %>
</body>
</html>